  "council": {
    "default_preset": "normal",
    "timeout": 180000,
    "councillor_execution_mode": "parallel",
    "councillor_retries": 3,
    "presets": {
      "normal": {
        "alpha": {
          "model": "openai/gpt-5.4",
          "prompt": "Role: Requirements and scope reviewer.\nFocus on whether the proposal satisfies the stated user goals, preserves constraints, and defines clear acceptance criteria. Identify missing requirements, ambiguous assumptions, unnecessary scope, and phase/checkpoint gaps. Prefer concrete clarifying questions and crisp scope decisions.\n"
        },
        "beta": {
          "model": "openai/gpt-5.4",
          "prompt": "Role: Architecture and trade-off reviewer.\nFocus on system boundaries, data flow, API/module changes, maintainability, testability, performance, and long-term design consequences. Compare viable options, state rationale and trade-offs, and recommend the simplest durable architecture.\n"
        },
        "gamma": {
          "model": "openai/gpt-5.4",
          "prompt": "Role: Implementation risk and validation reviewer.\nFocus on failure modes, migration/rollout risks, edge cases, required file/database/API changes, observability, and test strategy. Surface blockers early, call out unsafe fallbacks or hidden integration failures, and propose verifiable implementation steps.\n"
        }
      }
    }
  }
}
